$(function(){$(".preloader").fadeOut();$('[data-toggle="tooltip"]').tooltip();$('#myTable').DataTable({"aoColumnDefs":[{"bSortable":!1,"aTargets":["sorting_disabled"]}]})});var _lang='en';var _SELOCALE={'confirm':{de:'Bestätigen',en:'Confirm'},'abort':{de:'Abbrechen',en:'Abort'},'close':{de:'Schließen',en:'Close'},'download':{de:'Download',en:'Download'},'loading':{de:'<div class="d-flex align-items-center m-3"><strong>Wird geladen...</strong><div class="spinner-border ml-auto" style="width: 3rem; height: 3rem;" role="status" aria-hidden="true"></div></div>',en:'<div class="d-flex align-items-center m-3"><strong>Loading...</strong><div class="spinner-border ml-auto" style="width: 3rem; height: 3rem;" role="status" aria-hidden="true"></div></div>'},'fav.message':{de:'Der Song wurde zu Deinen Favoriten hinzugefügt',en:'The song has been added to your favourites'},'fav.title':{de:'Für neues Projekt vormerken',en:'Use for new project'},'fav.btncart':{de:'Zu meinen Favoriten',en:'Go to my favourites'},'cart.message':{de:'Der Song wurde in Deinen Warenkorb gelegt',en:'The song has been added to your cart'},'cart.title':{de:'Erweiterte Lizenz kaufen',en:'Get extended license'},'cart.btncart':{de:'Zu meinem Warenkorb',en:'Go to my cart'},'gb.message':{de:'Filmmusic.io lebt von den Einnahmen durch Werbung. Möchtest Du uns unterstützen? Dann kaufe eine lebenslang gültige Lizenz für Dein Lieblingsmusikstück - für nur 20 Euro. Registriere Dich kostenlos und klicke bei einem Song auf den Warenkorb.',en:'Filmmusic.io lives on the income from advertising. Would you like to support us? Then buy a lifetime license for your favorite piece of music - for only 20 Euro. Register for free and click on the shopping cart for a song.'},'comment.loggedin':{de:'Ups, leider können nur angemeldete Nutzer Kommentare schreiben. Registriere Dich jetzt, es ist kostenlos :)',en:'Sorry, only registered users can post comments. Register now, it is free!'},'comment.modal.title':{de:'Hinterlasse einen Kommentar zu diesem Song',en:'Leave a comment for this song'},'comment.modal.button':{de:'Kommentar abschicken',en:'Post comment'},'comment.modal.thanks':{de:'Danke, Dein Kommentar wurde gespeichert und ist nun auf der Song Seite sichtbar.',en:'Thank you, your comment was posted and is now visible on the song page.'},'addtocart.loggedin':{de:'Du musst Dich erst registrieren und einoggen, um erweiterte Lizenzen bestellen zu können. Die Registrierung ist kostenlos :)',en:'You have to register and log in to order extended licenses. Registration is free :)'},};function setranslate(key){return _SELOCALE[key][_lang]}
$(document).ready(function(){_lang=$('html').attr('lang')});function setCookie(name,value,days){if(days){var date=new Date();date.setTime(date.getTime()+(days*24*60*60*1000));var expires="; expires="+date.toGMTString()}else var expires="";document.cookie=name+"="+value+expires+"; path=/"}
function getCookie(name){var nameEQ=name+"=";var ca=document.cookie.split(';');for(var i=0;i<ca.length;i++){var c=ca[i];while(c.charAt(0)==' ')c=c.substring(1,c.length);if(c.indexOf(nameEQ)==0)return c.substring(nameEQ.length,c.length)}
return null}
function cookieExists(name){if(getCookie(name)==null){return!1}
return!0}
function removeCookie(name){setCookie(name,"",-1)}
function hasAB(){if(document.getElementById('syCVDUervv9QqPbg')){return!1}else{return!0}}
$(window).on("load",function(){if(hasAB()){$('.advocado .card-body').html('<div style="border-radius: 15px; padding: 30px; background: #212529; color: #FFF; font-weight:bold; font-size:120%;">'+setranslate('gb.message')+'</div>')}});function tour(){if(t3helpers.helpers.once('msg-musicnetwork')){t3helpers.popover.show({target:$('#filmmusic-network'),popover:$('#popover-network'),position:'br',content:!1});$('#popover-network').removeClass('hide');setTimeout(function(){$('#popover-network').fadeOut(1000)},5000)}}
function userProfile(){if(isUserLogged()){$.get("/api/?endpoint=user",function(data){if(parseInt(data.cart,10)>=1){$('#cart-icon .notify').removeClass('hide')}else{$('#cart-icon .notify').addClass('hide')}
$("#cart-count").html(data.cart);$('#user-username').html(data.username)},'json')}}
function isUserLogged(){if($("#favourites-icon").length){return!0}else{return!1}}
function seModalYoutube(){$('body').on('click','.modal-youtube',function(e){var ytid=$(this).attr('data-ytid');var html='<div class="embed-responsive embed-responsive-16by9">'+'                    <iframe class="embed-responsive-item" src="https://www.youtube.com/embed/'+ytid+'?autoplay=1"'+'                            frameborder="0"'+'                            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"'+'                            allowfullscreen></iframe>'+'                </div>';bootbox.dialog({title:'Video',message:html,size:'large'})})}
function SeFormLoader(){$('.se-formloader').each(function(){$(this).submit(function(event){var loader=bootbox.dialog({message:setranslate('loading'),closeButton:!1})})})}
function SeConfirm(){$.fn.hasAttr=function(name){return this.attr(name)!==undefined};$('.se-confirm').each(function(){$(this).click(function(event){var href=$(this).attr('href');event.preventDefault();bootbox.confirm({title:$(this).attr('data-confirm-title'),message:$(this).attr('data-confirm-text'),buttons:{confirm:{label:'<i class="fas fa-check-circle"></i> '+setranslate('confirm'),className:'btn-primary btn-lg'},cancel:{label:'<i class="fas fa-ban"></i> '+setranslate('abort'),className:'btn-danger btn-lg'}},callback:function(result){if(result==!0){var loader=bootbox.dialog({message:setranslate('loading'),closeButton:!1});location.href=href}}})})})}
function SeRedirect(){$.fn.hasAttr=function(name){return this.attr(name)!==undefined};$('.se-redirect').each(function(){$(this).click(function(event){var href=$(this).attr('href');event.preventDefault();bootbox.confirm({title:$(this).attr('data-confirm-title'),message:$(this).attr('data-confirm-text'),buttons:{confirm:{label:'<i class="fas fa-check-circle"></i> '+setranslate('confirm'),className:'btn-primary btn-lg'},cancel:{label:'<i class="fas fa-ban"></i> '+setranslate('abort'),className:'btn-danger btn-lg'}},callback:function(result){if(result==!0){var win=window.open(href,'_blank');win.focus()}}})})})}
function SeAlert(){$.fn.hasAttr=function(name){return this.attr(name)!==undefined};$('.se-alert').each(function(){$(this).click(function(event){event.preventDefault();bootbox.dialog({message:$(this).attr('data-alert-text'),buttons:{confirm:{label:$(this).attr('data-alert-btn'),className:'btn-primary btn-lg'}}})})})}
function ClipboardCopy(){function CopyToClipboard(containerid){if(window.getSelection){if(window.getSelection().empty){window.getSelection().empty()}else if(window.getSelection().removeAllRanges){window.getSelection().removeAllRanges()}}else if(document.selection){document.selection.empty()}
if(document.selection){var range=document.body.createTextRange();range.moveToElementText(document.getElementById(containerid));range.select().createTextRange();document.execCommand("copy")}else if(window.getSelection){var range=document.createRange();range.selectNode(document.getElementById(containerid));window.getSelection().addRange(range);document.execCommand("copy")}}
$('.clipboard').each(function(){$(this).click(function(event){CopyToClipboard($(this).attr('id'))})})}
function equalizePanels(){$('.equalizepanels').each(function(){var heights=[];$(this).find(".panel-body").each(function(){heights.push($(this).height())});heights.sort(function(a,b){return b-a});var minh=heights[0];$(this).find(".panel-body").height(minh)})}
