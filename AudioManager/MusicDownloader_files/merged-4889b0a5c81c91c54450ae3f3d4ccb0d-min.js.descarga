var trackedPlays={};function trackPlay(id,url){if(!trackedPlays[id]){trackedPlays[id]=!0;$.get(url,function(data){})}}
var nowPlaying=!1;var nowDuration=0;function initBottomPlayer(){var elm=$('#bottom-audioplayer');if(elm.length<=0){return}
var html=elm[0].outerHTML;$('#bottom-audioplayer').remove();$('.page-wrapper').append(html)}
function showBottomPlayer(){var audioplayer=$('.audioplayer.isplaying');var uid=audioplayer.attr('data-uid');var artist=audioplayer.attr('data-artist');var title=audioplayer.attr('data-title');var playerid='song'+audioplayer.attr('data-player-id');$("#bottom-audioplayer .bottom-audioplayer_status_title").html(title+' ('+artist+')');$("#bottom-audioplayer").removeClass('hide');$("#bottom-audioplayer").hide();$("#bottom-audioplayer").fadeIn();var volume=$('#volume').val();soundManager.setVolume(volume);$("#bottom-audioplayer .music-comment-action a").attr('data-uid',uid);$("#bottom-audioplayer .music-comment-action a").attr('data-seconds',0);$("#bottom-audioplayer").find('.play').off();$("#bottom-audioplayer").find('.play').click(function(e){if($("#bottom-audioplayer").find('.start').hasClass('hidden')){soundManager.pause(playerid)}else{soundManager.play(playerid)}});$("#bottom-audioplayer .bottom-audioplayer_x").click(function(e){soundManager.stopAll();hideBottomPlayer()});$("#bottom-audioplayer").find(".bottom-audioplayer_status_overlay").click(function(e){var parentOffset=$(this).offset();var relX=e.pageX-parentOffset.left;var relY=e.pageY-parentOffset.top;var newposition=Math.round((nowDuration/$(this).width())*relX);soundManager.setPosition(nowPlaying,newposition)})}
function hideBottomPlayer(){$("#bottom-audioplayer").fadeOut()}
var playercount=0;function audioplayer(audioplayer){playercount++;audioplayer.attr('data-player-id',playercount);var uid=audioplayer.attr('data-uid');var playerid='song'+playercount;var mp3=audioplayer.attr('data-mp3');var timecode=audioplayer.attr('data-timecode');var trackplayUri=audioplayer.attr('data-track');var artist=audioplayer.attr('data-artist');var title=audioplayer.attr('data-title');var loaderwidth=parseInt(audioplayer.find('.waveform-loader').width());var initialized=!1;var isplaying=!1;var mySoundmanager;audioplayer.find(".waveform").click(function(e){var parentOffset=$(this).offset();var relX=e.pageX-parentOffset.left;var relY=e.pageY-parentOffset.top;var newposition=Math.round((duration/$(this).width())*relX);soundManager.setPosition(playerid,newposition)});audioplayer.find(".music-comment-section").click(function(e){var parentOffset=$(this).offset();var relX=e.pageX-parentOffset.left;var relY=e.pageY-parentOffset.top;audioplayer.find(".music-comment-action").removeClass('hide');var commentwidth=audioplayer.find(".music-comment-action").outerWidth();var timecode=Math.round((nowDuration/$(this).width())*relX);audioplayer.find(".music-comment-action a").attr('data-seconds',Math.round(timecode/1000));audioplayer.find(".music-comment-action a").attr('data-uid',uid);audioplayer.find(".music-comment-action").css('left',(relX-commentwidth/2)+'px')});audioplayer.find('.play').click(function(e){if(nowPlaying!=playerid){soundManager.stopAll();soundManager.unload(nowPlaying);nowPlaying=playerid;$('.audioplayer').removeClass('isplaying');audioplayer.addClass('isplaying');audioplayer.find(".music-comment-section").removeClass('hide')}
showBottomPlayer();if(initialized==!1){soundManager.setup({onready:function(){mySoundmanager=soundManager.createSound({id:playerid,url:mp3,stream:!0,whileloading:function(){var percent=Math.round((100/this.bytesTotal)*this.bytesLoaded);var loadpos=Math.round((loaderwidth/100)*percent);audioplayer.find('.waveform-loader').attr('style','clip: rect(auto,'+loadpos+'px,auto,auto);');if(this.bytesLoaded==this.bytesTotal){audioplayer.find('.waveform-loader').hide()}else{audioplayer.find('.waveform-loader').show()}},whileplaying:function(){duration=this.duration;nowDuration=this.duration;scrubwidth=audioplayer.find('.waveform-bg').width();var scrubposition=Math.round((scrubwidth/this.duration)*this.position);var timenow=secondstotime(Math.round(this.position/1000));var percent=Math.round((100/this.duration)*this.position);audioplayer.find('.waveform-fg').attr('style','clip: rect(auto,'+scrubposition+'px,auto,auto);');audioplayer.find('.timecode').html(timenow+' / '+timecode);$('.bottom-audioplayer_statusbar').css('width',percent+'%');if(this.bytesLoaded==this.bytesTotal){audioplayer.find('.waveform-loader').hide()}},onpause:function(){audioplayer.find('.play .start').removeClass('hidden');audioplayer.find('.play .pause').addClass('hidden');$('#bottom-audioplayer').find('.play .start').removeClass('hidden');$('#bottom-audioplayer').find('.play .pause').addClass('hidden');isplaying=!1},onresume:function(){audioplayer.find('.play .start').addClass('hidden');audioplayer.find('.play .pause').removeClass('hidden');$('#bottom-audioplayer').find('.play .start').addClass('hidden');$('#bottom-audioplayer').find('.play .pause').removeClass('hidden');isplaying=!0},onplay:function(){audioplayer.find('.play .start').addClass('hidden');audioplayer.find('.play .pause').removeClass('hidden');$('#bottom-audioplayer').find('.play .start').addClass('hidden');$('#bottom-audioplayer').find('.play .pause').removeClass('hidden');isplaying=!0;nowDuration=this.duration;trackPlay(uid,trackplayUri)},onstop:function(){audioplayer.find('.play .start').removeClass('hidden');audioplayer.find('.play .pause').addClass('hidden');$('#bottom-audioplayer').find('.play .start').removeClass('hidden');$('#bottom-audioplayer').find('.play .pause').addClass('hidden');audioplayer.find('.waveform-fg').attr('style','clip: rect(auto,0px,auto,auto);');soundManager.unload(nowPlaying);audioplayer.find('.timecode').html(timecode);isplaying=!1;nowPlaying=!1;hideBottomPlayer();audioplayer.find('.waveform-loader').hide();audioplayer.find(".music-comment-section").addClass('hide')},onfinish:function(){audioplayer.find('.play .start').removeClass('hidden');audioplayer.find('.play .pause').addClass('hidden');$('#bottom-audioplayer').find('.play .start').removeClass('hidden');$('#bottom-audioplayer').find('.play .pause').addClass('hidden');audioplayer.find('.waveform-fg').attr('style','clip: rect(auto,0px,auto,auto);');soundManager.unload(nowPlaying);audioplayer.find('.jsplayer-time-now .jsplayer-data').html(secondstotime(0));audioplayer.find(".music-comment-section").addClass('hide');isplaying=!1;nowPlaying=!1;hideBottomPlayer()},});initialized=!0;mySoundmanager.setVolume($('#volume').val());mySoundmanager.play()}})}else if(isplaying){mySoundmanager.pause()}else{mySoundmanager.play()}})}
function writeComment(){$('body').on('click','.music-comment-action',function(event){event.preventDefault();if(!isUserLogged()){bootbox.alert(setranslate('comment.loggedin'));return}
var dataUid=$(this).attr('data-uid');var dataSeconds=$(this).attr('data-seconds');var dataRefresh=$(this).attr('data-refresh');var locale={OK:'OK',CONFIRM:setranslate('comment.modal.button'),CANCEL:setranslate('abort')};bootbox.addLocale('custom',locale);bootbox.prompt({title:setranslate('comment.modal.title'),locale:'custom',inputType:'textarea',callback:function(comment){if(comment==null||comment.length==0){}else{$.post("/api/?endpoint=musiccomment",{comment:comment,music:dataUid,seconds:dataSeconds},function(data){bootbox.alert(setranslate('comment.modal.thanks'),function(){if(dataRefresh=='yes'){location.reload()}})},'json')}}})})}
function emailDownload(){$('body').on('click','.music-sendemail-action',function(event){event.preventDefault();var href=$(this).attr('data-form');var loader=bootbox.dialog({message:setranslate('loading'),closeButton:!1});$.get(href,function(html){html=$('<div></div>').append(html);loader.modal('hide');bootbox.dialog({title:"Song per E-mail erhalten",message:html,buttons:{cancel:{label:'Schließen',className:'btn-default btn-lg'}},})})})}
function downloadSongs(){$('body').on('click','.music-download-action',function(event){bootbox.hideAll();event.preventDefault();var href=$(this).attr('data-form');$.get(href,function(html){html=$('<div></div>').append(html);var downloadLink=html.find('.download-mp3-link').attr('href');html.find('.download-mp3-link').remove();bootbox.confirm({title:"Download",message:html,size:'large',buttons:{cancel:{label:setranslate('abort'),className:'btn-secondary btn-lg'},confirm:{label:setranslate('download'),className:'btn-primary btn-lg'}},callback:function(result){if(result==!0){location.href=downloadLink}}})})})}
function addToFavourites(){$('body').on('click','.music-favourites-action',function(event){event.preventDefault();var hrefAdd=$(this).attr('data-hrefadd');var hrefCart=$(this).attr('data-hrefcart');var loader=bootbox.dialog({message:setranslate('loading'),closeButton:!1});$.get(hrefAdd,function(html){loader.modal('hide');userProfile();$.notify(setranslate('fav.message'),"success")})})}
function addToCart(){$('body').on('click','.music-cart-action',function(event){bootbox.hideAll();event.preventDefault();if(!isUserLogged()){bootbox.alert(setranslate('addtocart.loggedin'));return}
var hrefAdd=$(this).attr('data-hrefadd');var hrefCart=$(this).attr('data-hrefcart');var loader=bootbox.dialog({message:setranslate('loading'),closeButton:!1});$.get(hrefAdd,function(html){loader.modal('hide');userProfile();bootbox.confirm({title:setranslate('cart.title'),message:setranslate('cart.message'),buttons:{confirm:{label:setranslate('cart.btncart'),className:'btn-primary btn-lg'},cancel:{label:setranslate('close'),className:'btn-default btn-lg'}},callback:function(result){if(result==!0){location.href=hrefCart}}})})})}
function volumeBar(){var exists=cookieExists('volume');if(exists){var volume=getCookie('volume')}else{var volume=100}
$('#volume').on('input',function(){soundManager.setVolume($(this).val());setCookie('volume',$(this).val(),365)});soundManager.setVolume(volume);$('#volume').val(volume)}
$(function(){$('.audioplayer').each(function(e){audioplayer($(this))});initBottomPlayer();downloadSongs();emailDownload();addToCart();addToFavourites();writeComment();volumeBar()});
